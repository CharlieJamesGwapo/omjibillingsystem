# Server
PORT=8080

# Database (used by backend)
DATABASE_URL=postgres://omji:password@db:5432/billing?sslmode=disable

# Database (used by docker-compose for postgres container)
POSTGRES_USER=omji
POSTGRES_PASSWORD=password
POSTGRES_DB=billing

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-secret

# SMS Provider (skysms or mock)
SMS_PROVIDER=skysms
SMS_API_KEY=your-skysms-api-key-here
SMS_BASE_URL=https://skysms.skyio.site/api

# MikroTik RouterOS API
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:5173
